# Liberté — environment variables. Copy to .env and fill in real values.
# .env is gitignored; never commit real keys.

# --- Supabase (server-side names, read via process.env in handlers) ---
SUPABASE_URL=https://tpqoszkffdmxdyskdnyi.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# --- Supabase (client-side, inlined into the browser bundle at build time) ---
# Never put secrets behind VITE_* — they ship to the client.
VITE_SUPABASE_URL=https://tpqoszkffdmxdyskdnyi.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_PROJECT_ID=tpqoszkffdmxdyskdnyi

# --- OpenAI (AI tutor, STT, TTS, activity correction) — server only ---
OPENAI_API_KEY=sk-...

# --- Resend (welcome/admin emails in the public signup endpoint) ---
RESEND_API_KEY=re_...

# --- Lovable email infrastructure (pgmq queue worker) ---
LOVABLE_API_KEY=
LOVABLE_SEND_URL=

# --- Telegram integration (bot link, reminders, broadcast) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Cron endpoint auth (src/routes/api/telegram/reminders.ts) ---
CRON_SECRET=
